   "id": "624f71bf",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.groupby(\"team\")[\"runs\"].mean()\n",
    "\n",
    "SQL translation: \n",
    "SELECT team,avg(runs) GROUP BY team\n",
    "\n",
    "df.groupby(\"team\")[\"runs\"].agg([\"mean\",\"max\",\"min\",\"sum\"])"
   ]
  },
